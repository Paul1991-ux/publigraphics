  number = {5},
  pages = {1409--1443},
  doi = {10.1111/j.1468-0262.2004.00539.x},
  abstract = {Examines the impact of mandated political representation for women in Indian village councils on policy decisions, finding that women leaders invest more in public goods relevant to women's concerns.}
}

