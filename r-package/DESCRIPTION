Package: publigraphics
Title: Visual and Narrative Profiling of Researchers' Scientific Output
Version: 0.1.0
Authors@R:
    person(
      given  = "Paul",
      family = "Wambo",
      email  = "paulwambo2@gmail.com",
      role   = c("aut", "cre"),
      comment = c(ORCID = "0009-0005-6062-9227")
